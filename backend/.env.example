CEREBRAS_API_KEY=your-cerebras-key
GROQ_API_KEY=your-groq-key
GEMINI_API_KEY=your-gemini-key
# MiniMax M2.7 — 229B MoE, SOTA real-world engineering (get key at platform.minimax.io)
MINIMAX_API_KEY=your-minimax-key
NEWS_API_KEY=your-newsapi-key
TAVILY_API_KEY=your-tavily-api-key
SERPAPI_KEY=your-serpapi-key
GOOGLE_FACTCHECK_API_KEY=your-google-factcheck-key
DATABASE_URL=sqlite:///./fake_news.db
JWT_SECRET=your-random-secret
GOOGLE_CLIENT_ID=your-google-client-id
SMTP_USER=your-gmail@gmail.com
BREVO_API_KEY=your-brevo-api-key

# ── ML Models ─────────────────────────────────────────────────
# Set to your fine-tuned HF model ID after running train_finetune_ensemble.py
# Leave empty to use default: Arko007/fact-check1-v3-final (DeBERTa-v3-large, 99.98% acc)
DEBERTA_MODEL=

# Enable fine-tuned ensemble (both RoBERTa + DeBERTa fine-tuned models)
# Run backend/training/train_finetune_ensemble.py first to generate ensemble_config.json
ENABLE_ENSEMBLE=false

# Force load transformer even on low-RAM environments (not recommended on free tier)
FORCE_TRANSFORMER_LOAD=false

# HuggingFace token (for downloading private/gated models)
HF_TOKEN=your-hf-token

# ── Phase 2.4: Social Graph Analysis (Optional) ──────────────
# Enable social media spread tracking
SOCIAL_GRAPH_ENABLED=false

# Twitter/X API v2 (Bearer Token from Developer Portal)
# Get from: https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Reddit API (Create app at https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=FactCheckerAI/1.0

# ── Wikidata entity verification (optional, disabled by default) ──
WIKIDATA_ENABLED=false

# ── Redis cache (optional, improves performance significantly) ────
# REDIS_URL=redis://localhost:6379/0
# REDIS_ENABLED=false
